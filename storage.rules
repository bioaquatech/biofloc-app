rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Logos des fermes — lecture publique, écriture responsable de la ferme
    match /logos/{farmCode}/{file} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.farmCode == farmCode
        && request.resource.size < 2 * 1024 * 1024  // max 2MB
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.farmCode == farmCode
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['Administrateur','SuperAdmin']);
    }
    // Tout le reste — refusé
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
