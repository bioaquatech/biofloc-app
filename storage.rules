rules_version = '2';

// ════════════════════════════════════════════════════════════════════
//  Firebase Storage — BioFloc ERP
//  Bucket : bio-aqua-tech.firebasestorage.app
//  Accès réservé aux utilisateurs authentifiés ; chaque ferme est
//  cloisonnée via le profil users/{uid}.farmCode (lu dans Firestore).
//  Tout chemin non listé est refusé.
// ════════════════════════════════════════════════════════════════════
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function userData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    // L'utilisateur appartient-il à cette ferme ?
    function isSameFarm(farmCode) {
      return isAuth() && userData().farmCode == farmCode;
    }
    // Rôle administrateur / superadmin (liste alignée sur firestore.rules)
    function isAdmin() {
      return isAuth() && userData().role in ['Administrateur', 'SuperAdmin', 'superadmin'];
    }

    // ── Logos de ferme ───────────────────────────────────────────────
    // logos/{farmCode}/logo.png|jpg|…
    match /logos/{farmCode}/{file} {
      // Lecture : tout utilisateur authentifié (affichage inter-fermes toléré).
      allow read: if isAuth();
      // Écriture : membre de la ferme · image · max 2 Mo.
      // (contentType vient du client, non garanti — la taille reste appliquée.)
      allow write: if isSameFarm(farmCode)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // Suppression : membre de la ferme ET rôle admin/superadmin.
      allow delete: if isSameFarm(farmCode) && isAdmin();
    }

    // ── Sauvegardes automatiques (classées par ferme) ────────────────
    // backups/{farmCode}/{horodatage}.json
    match /backups/{farmCode}/{file} {
      // Lecture / restauration : membre de la ferme, ou admin/superadmin.
      allow read: if isSameFarm(farmCode) || isAdmin();
      // Écriture : membre de la ferme · JSON · max 25 Mo.
      allow write: if isSameFarm(farmCode)
        && request.resource.contentType.matches('application/json.*')
        && request.resource.size < 25 * 1024 * 1024;
      // Suppression (purge des > 10 dernières) : membre de la ferme ou admin.
      allow delete: if isSameFarm(farmCode) || isAdmin();
    }

    // ── Tout le reste : refusé ───────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
